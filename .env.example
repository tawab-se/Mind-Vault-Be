# Application
NODE_ENV=development
PORT=3000
APP_NAME=mind-vault-be

# Database (uncomment and configure when needed)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=username
# DATABASE_PASSWORD=password
# DATABASE_NAME=mind_vault_db

# JWT (uncomment and configure when needed)
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRES_IN=3600

# API
API_PREFIX=api
API_VERSION=v1

# CORS
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Logging
LOG_LEVEL=debug